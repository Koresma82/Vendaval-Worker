# ---- Firebase (mesmo projeto do Vendaval) ----
# Base64 do serviceAccountKey.json (evita o bug do JSON partido no Raw Editor)
FIREBASE_SERVICE_ACCOUNT_B64=
FIREBASE_STORAGE_BUCKET=vendaval-prod-f55eb.firebasestorage.app

# ---- IMAP (Gmail) ----
# O hello@tech-ramen.com reencaminha para o Gmail via Cloudflare Email Routing.
# IMAP_PASSWORD tem de ser uma APP PASSWORD do Google (16 caracteres, sem espacos):
#   myaccount.google.com -> Seguranca -> Verificacao em duas etapas (tem de estar ON)
#   -> Passwords de aplicacoes -> criar "Vendaval Worker"
# NUNCA uses a password normal da conta Google - nao funciona e e inseguro.
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=koresma@gmail.com
IMAP_PASSWORD=

# ---- Claude API ----
ANTHROPIC_API_KEY=

# ---- Instagram (opcional - deixar vazio desativa publicacao automatica) ----
META_ACCESS_TOKEN=
IG_USER_ID=

# ---- LinkedIn pagina de empresa (opcional) ----
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORG_ID=

# ---- Comportamento ----
POSTS_POR_SEMANA_POR_PROJETO=3
